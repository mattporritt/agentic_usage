# API keys (optional — dashboard works without them, shows local data only)
ANTHROPIC_ADMIN_KEY=sk-ant-admin-...
OPENAI_ADMIN_KEY=sk-...

# Claude plan info — run ./scripts/init_plan.sh to populate these automatically.
# Only needs re-running when your subscription plan changes.
CLAUDE_SUBSCRIPTION_TYPE=pro
CLAUDE_RATE_LIMIT_TIER=

# Host directory paths (docker-compose volume sources).
# Defaults work for standard macOS installs; override only if yours differ.
CLAUDE_HOST_DIR=~/.claude
CODEX_HOST_DIR=~/.codex
DATA_DIR=./data
LOG_DIR=./logs

# Polling interval in seconds
POLL_INTERVAL_SECONDS=60
